{
  "name": "gabrielveras.dev",
  "version": "2.1.6",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "format": "prettier --write \"src/**/*.{ts,html,scss,json}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,json}\" \"*.{json,md}\"",
    "quality": "npm run lint && npm run format:check && npm run build",
    "sync:version": "node scripts/sync-version.mjs",
    "prestart": "npm run sync:version",
    "prebuild": "npm run sync:version",
    "prequality": "npm run sync:version",
    "prepare": "husky"
  },
  "private": true,
  "packageManager": "npm@11.13.0",
  "lint-staged": {
    "src/**/*.{ts,html,scss,json}": [
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.13",
    "@angular/cli": "^21.2.13",
    "@angular/compiler-cli": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "angular-eslint": "21.4.0",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.59.2",
    "vitest": "^4.0.8"
  }
}
